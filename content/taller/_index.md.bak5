  datasets: [{
    label: 'Lifetime funding',
    data: [158333963, 122078251, 95256121, 91503919, 75186768, 73675617, 72759317, 67076086, 52206849, 43939517, 42508361, 41445545, 38748603, 37501769, 33956580],
    backgroundColor: '#0969DA',
    borderRadius: 2,
    grants: [751, 626, 631, 247, 249, 309, 281, 148, 152, 215, 175, 123, 22, 120, 52]
  }]
},
options: {
  indexAxis: 'y',
  responsive: true,
  maintainAspectRatio: false,
  plugins: {
    legend: { display: false },
    tooltip: {
      callbacks: {
        label: function(ctx) {
          const g = ctx.dataset.grants[ctx.dataIndex];
          return '$' + Math.round(ctx.parsed.x).toLocaleString() + ' · ' + g + ' grants';
        }
      }
    }
  },
  scales: {
    x: {
      beginAtZero: true,
      ticks: { callback: function(v) { return '$' + (v/1e6).toFixed(0) + 'M'; } }
    },
    y: {
      ticks: { autoSkip: false, font: { size: 11 } }
    }
  }
}
{{< /chart >}}

