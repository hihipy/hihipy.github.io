library(tidysynth)
library(causaldata)
library(dplyr)
library(rlang)
library(jsonlite)
out_path <- "~/Library/CloudStorage/ProtonDrive-philgbd@pm.me-folder/Code/coding-workspace/hihipy.github.io/content/archivo/texas-synthetic-control/texas_synth_charts.md"
treat_year <- 1993
pre_win <- 1986:1993                   # predictor / optimization window
full_win <- 1986:1999                  # analysis window (1985 NA, 2000 sparse)
drop_donors <- c("California", "New York")  # only states with in-window NA gaps
texas_panel <- causaldata::texas |>
filter(!state %in% drop_donors, year >= min(full_win), year <= max(full_win))
# ---------------------------------------------------------------------------
# Guard: refuse to fit on incomplete data
# ---------------------------------------------------------------------------
fit_cols <- c(
"bmprison", "wmprison",
"income", "ur", "poverty", "alcohol", "aidscapita", "black", "perc1519"
)
na_counts <- texas_panel |>
summarise(across(all_of(fit_cols), \(x) sum(is.na(x))))
if (any(unlist(na_counts) > 0)) {
print(na_counts)
stop("NA present in the analysis window after trimming; inspect the columns above.")
}
cat(sprintf(
"Panel ready: %d states, years %d-%d, no NA in fit columns.\n",
dplyr::n_distinct(texas_panel$state), min(full_win), max(full_win)
))
# ---------------------------------------------------------------------------
# Recipe builder (parametrised by predictor selection and placebo flag)
# ---------------------------------------------------------------------------
build_sc <- function(panel, outcome, covars, lags, pre_window, placebos) {
out_sym <- rlang::sym(outcome)
s <- rlang::inject(
synthetic_control(
panel,
outcome = !!out_sym,
unit = state,
time = year,
i_unit = "Texas",
i_time = 1993,
generate_placebos = placebos
)
)
for (v in covars) {
e <- rlang::expr(mean(!!rlang::sym(v), na.rm = TRUE))
s <- rlang::inject(generate_predictor(s, time_window = pre_window, !!v := !!e))
}
for (yr in lags) {
nm <- paste0("lag_", yr)
s <- rlang::inject(generate_predictor(s, time_window = yr, !!nm := !!out_sym))
}
s
}
finish_sc <- function(s, pre_window) {
s |>
generate_weights(optimization_window = pre_window) |>
generate_control()
}
# Does this spec actually solve (treated-only, both outcomes)? The real test.
spec_solves <- function(panel, covars, lags, pre_window) {
for (oc in c("bmprison", "wmprison")) {
ok <- tryCatch({
finish_sc(build_sc(panel, oc, covars, lags, pre_window, placebos = FALSE), pre_window)
TRUE
}, error = function(e) FALSE)
if (!ok) return(FALSE)
}
TRUE
}
# ---------------------------------------------------------------------------
# Spec ladder: richest first, accept the first that converges for both
# ---------------------------------------------------------------------------
ladder <- list(
list(covars = c("income", "ur", "poverty", "alcohol", "aidscapita", "black", "perc1519"),
lags = c(1988, 1990, 1992)),
list(covars = c("income", "ur", "poverty", "alcohol", "aidscapita", "black", "perc1519"),
lags = c(1988)),
list(covars = c("income", "poverty", "ur", "black"),
lags = c(1988, 1992)),
list(covars = c("income", "poverty", "black"),
lags = c(1988)),
list(covars = character(0),
lags = c(1988, 1990, 1992)),
list(covars = character(0),
lags = c(1988, 1992))
)
cat("\nSelecting a spec that the optimizer actually solves:\n")
sel <- NULL
for (i in seq_along(ladder)) {
sp <- ladder[[i]]
cat(sprintf(
"  rung %d: covars=[%s] lags=[%s] ... ",
i,
if (length(sp$covars)) paste(sp$covars, collapse = ", ") else "none",
paste(sp$lags, collapse = ", ")
))
if (spec_solves(texas_panel, sp$covars, sp$lags, pre_win)) {
cat("solves both outcomes.\n")
sel <- sp
sel$rung <- i
break
}
cat("singular, stepping down.\n")
}
if (is.null(sel)) {
stop("No spec on the ladder converged; the data or window needs another look.")
}
cat(sprintf(
"\nChosen spec (rung %d) -> covariates: %s | lags: %s\n",
sel$rung,
if (length(sel$covars)) paste(sel$covars, collapse = ", ") else "(none)",
paste(sel$lags, collapse = ", ")
))
# ---------------------------------------------------------------------------
# Final fit with placebos, then verify inference is non-degenerate
# ---------------------------------------------------------------------------
cat("\nFitting with placebos:\n")
sc_black <- finish_sc(build_sc(texas_panel, "bmprison", sel$covars, sel$lags, pre_win, placebos = TRUE), pre_win)
cat("  black: fitted\n")
sc_white <- finish_sc(build_sc(texas_panel, "wmprison", sel$covars, sel$lags, pre_win, placebos = TRUE), pre_win)
cat("  white: fitted\n")
sig_b <- grab_significance(sc_black)
sig_w <- grab_significance(sc_white)
if (any(is.na(sig_b$mspe_ratio)) || any(is.na(sig_w$mspe_ratio))) {
warning("NA in a significance table; some donor placebo did not fit. Inspect before trusting inference.")
}
# ---------------------------------------------------------------------------
# Palette and chart helpers
# ---------------------------------------------------------------------------
ok <- list(
black = "#000000",
orange = "#E69F00",
skyblue = "#56B4E9",
green = "#009E73",
yellow = "#F0E442",
blue = "#0072B2",
vermill = "#D55E00",
purple = "#CC79A7"
)
grid_grey <- "#888888"
placebo_grey <- "rgba(140,140,140,0.30)"
recs <- function(x, y) {
Map(function(a, b) list(x = a, y = b), as.numeric(x), as.numeric(y))
}
pad_range <- function(v, frac = 0.06) {
v <- v[is.finite(v)]
lo <- min(v)
hi <- max(v)
span <- hi - lo
if (span == 0) span <- abs(hi) + 1
lo_pad <- lo - span * frac
hi_pad <- hi + span * frac
# round bounds outward to a clean step scaled to the data magnitude,
# so axes land on round numbers instead of arbitrary decimals
step <- 10^floor(log10(span))
if (span / step < 2) {
step <- step / 5
} else if (span / step < 5) {
step <- step / 2
}
c(floor(lo_pad / step) * step, ceiling(hi_pad / step) * step)
}
marker_ds <- function(ylo, yhi, label = "1993: prison expansion begins") {
list(
label = label,
data = list(
list(x = treat_year, y = ylo),
list(x = treat_year, y = yhi)
),
borderColor = grid_grey,
borderWidth = 1.5,
borderDash = c(6, 4),
pointRadius = 0,
pointHitRadius = 0,
fill = FALSE,
order = 99
)
}
x_scale <- function(yrs) {
list(
type = "linear",
min = min(yrs),
max = max(yrs),
ticks = list(stepSize = 3, precision = 0, format = list(useGrouping = FALSE)),
title = list(display = TRUE, text = "Year")
)
}
# One line dataset. dash = NULL for solid, c(7, 4) for dashed.
ds_line <- function(label, x, y, color, width = 2.5, dash = NULL) {
d <- list(
label = label,
data = recs(x, y),
borderColor = color,
backgroundColor = color,
borderWidth = width,
pointRadius = 0,
tension = 0.15,
fill = FALSE
)
if (!is.null(dash)) d$borderDash <- dash
d
}
# Assemble a full chart config: core datasets + 1993 marker + axes.
assemble <- function(core, yrange, ytitle, yrs,
legend_display = TRUE, tooltip = TRUE) {
datasets <- c(core, list(marker_ds(yrange[1], yrange[2])))
list(
type = "line",
data = list(datasets = datasets),
options = list(
responsive = TRUE,
maintainAspectRatio = FALSE,
interaction = list(mode = "index", intersect = FALSE),
scales = list(
x = x_scale(yrs),
y = list(
min = yrange[1],
max = yrange[2],
title = list(display = TRUE, text = ytitle)
)
),
plugins = list(
legend = list(display = legend_display, position = "bottom"),
tooltip = list(enabled = tooltip)
)
)
)
}
emit_inner <- function(cfg) {
j <- jsonlite::toJSON(cfg, auto_unbox = TRUE, pretty = TRUE, digits = 6, na = "null")
j <- trimws(j)
j <- sub("^\\{", "", j)
j <- sub("\\}\\s*$", "", j)
sub("[[:space:]]+$", "", j)
}
wrap_block <- function(inner, headline, sub) {
paste0(
'<div class="pgbd-case-chart-wrap">\n',
'<p class="pgbd-case-chart-headline">', headline, "</p>\n",
'<p class="pgbd-case-chart-sub">', sub, "</p>\n\n",
"{{< chart >}}\n", inner, "\n{{< /chart >}}\n\n",
"</div>\n"
)
}
# ---------------------------------------------------------------------------
# Pull data and derive the figures the prose cites
# ---------------------------------------------------------------------------
b <- grab_synthetic_control(sc_black)
w <- grab_synthetic_control(sc_white)
b$gap <- b$real_y - b$synth_y
w$gap <- w$real_y - w$synth_y
b$pct <- b$gap / b$synth_y * 100
w$pct <- w$gap / w$synth_y * 100
yrs <- sort(unique(b$time_unit))
post_years <- 1994:1999
bp <- b |> filter(time_unit %in% post_years)
wp <- w |> filter(time_unit %in% post_years)
black_mean_pct <- mean(bp$pct)
white_mean_pct <- mean(wp$pct)
ratio_prop <- black_mean_pct / white_mean_pct
black_abs_1999 <- round(b$gap[b$time_unit == 1999])
white_abs_1999 <- round(w$gap[w$time_unit == 1999])
ratio_abs_1999 <- black_abs_1999 / white_abs_1999
n_units <- nrow(sig_b)
rank_b <- sig_b$rank[sig_b$unit_name == "Texas"]
rank_w <- sig_w$rank[sig_w$unit_name == "Texas"]
cat("\nFigures cited in the prose (verify these read correctly):\n")
cat(sprintf("  proportional: black %.0f%% vs white %.0f%% post-1993, ratio %.2fx\n",
black_mean_pct, white_mean_pct, ratio_prop))
cat(sprintf("  absolute 1999: black %d vs white %d, ratio %.2fx\n",
black_abs_1999, white_abs_1999, ratio_abs_1999))
cat(sprintf("  placebo rank: black %d/%d, white %d/%d\n",
rank_b, n_units, rank_w, n_units))
# ---------------------------------------------------------------------------
# Chart configs (5): proportional lead, absolute, two fits, placebo
# ---------------------------------------------------------------------------
# 1. Proportional gaps (lead)
yr_prop <- pad_range(c(b$pct, w$pct, 0))
cfg1 <- assemble(
list(
ds_line("Black male gap (% of synthetic)", b$time_unit, round(b$pct, 1), ok$vermill),
ds_line("White male gap (% of synthetic)", w$time_unit, round(w$pct, 1), ok$blue)
),
yr_prop, "Gap vs Synthetic (%)", yrs
)
# 2. Absolute gaps (prisoners)
yr_abs <- pad_range(c(b$gap, w$gap, 0))
cfg2 <- assemble(
list(
ds_line("Black male gap (prisoners)", b$time_unit, round(b$gap), ok$vermill),
ds_line("White male gap (prisoners)", w$time_unit, round(w$gap), ok$blue)
),
yr_abs, "Prisoners (Gap vs Synthetic)", yrs
)
# 3. Black male fit
yr_bfit <- pad_range(c(b$real_y, b$synth_y))
cfg3 <- assemble(
list(
ds_line("Texas (observed)", b$time_unit, round(b$real_y), ok$vermill),
ds_line("Synthetic Texas", b$time_unit, round(b$synth_y), ok$purple, width = 2, dash = c(7, 4))
),
yr_bfit, "Black Male Prisoners", yrs
)
# 4. White male fit
yr_wfit <- pad_range(c(w$real_y, w$synth_y))
cfg4 <- assemble(
list(
ds_line("Texas (observed)", w$time_unit, round(w$real_y), ok$blue),
ds_line("Synthetic Texas", w$time_unit, round(w$synth_y), ok$purple, width = 2, dash = c(7, 4))
),
yr_wfit, "White Male Prisoners", yrs
)
# 5. Placebo spaghetti on the raw black-male gap (matches the permutation test)
pb <- grab_synthetic_control(sc_black, placebo = TRUE)
pb$gap <- pb$real_y - pb$synth_y
ids <- unique(pb$.id)
treated_id <- unique(pb$.id[pb$.placebo == 0])
placebo_datasets <- lapply(ids, function(id) {
d <- pb[pb$.id == id, ]
d <- d[order(d$time_unit), ]
is_treat <- identical(id, treated_id)
ds_line(
id, d$time_unit, round(d$gap),
if (is_treat) ok$vermill else placebo_grey,
width = if (is_treat) 2.8 else 1
)
})
for (k in seq_along(placebo_datasets)) {
placebo_datasets[[k]]$order <- if (identical(ids[k], treated_id)) 0 else 50
}
gap5 <- pad_range(c(pb$gap, 0))
cfg5 <- assemble(
placebo_datasets, gap5, "Prisoners (Gap vs Synthetic)", yrs,
legend_display = FALSE, tooltip = FALSE
)
# ---------------------------------------------------------------------------
# Headlines and subtitles (numbers injected from the fit)
# ---------------------------------------------------------------------------
sub1 <- sprintf(
paste0(
"Gap between observed Texas and its synthetic control, as a share of the ",
"counterfactual. Both groups jump after 1993, averaging about %.0f%% above ",
"synthetic for Black men and %.0f%% for white men through 1999. The Black ",
"male gap runs about %.1f times the white gap, and that ratio holds steady ",
"across the post-period."
),
black_mean_pct, white_mean_pct, ratio_prop
)
sub2 <- sprintf(
paste0(
"The same gap measured in prisoners. By 1999 the expansion is associated ",
"with roughly %s additional Black male prisoners against %s white, an ",
"absolute gap of about %.1f times. It is wider than the proportional gap ",
"because Black incarceration started from a higher base."
),
format(round(black_abs_1999, -2), big.mark = ","),
format(round(white_abs_1999, -2), big.mark = ","),
ratio_abs_1999
)
sub3 <- "Pre-1993 fit and post-1993 divergence for the Black male series."
sub4 <- paste0(
"The same construction for white men. The effect is large here too, not ",
"absent, which is the point: the expansion raised incarceration for both ",
"groups."
)
sub5 <- sprintf(
paste0(
"Each grey line reassigns the 1993 treatment to a donor state, on the raw ",
"prisoner gap used for the permutation test. Texas posts the largest ",
"post-to-pre MSPE ratio of all %d units (rank %d)."
),
n_units, rank_b
)
# ---------------------------------------------------------------------------
# Write
# ---------------------------------------------------------------------------
out <- paste0(
wrap_block(emit_inner(cfg1), "Both Groups Rise, Black Men Bear the Larger Share", sub1),
wrap_block(emit_inner(cfg2), "Measured in People, the Gap Is Wider", sub2),
wrap_block(emit_inner(cfg3), "Black Male Incarceration: Texas vs Synthetic Texas", sub3),
wrap_block(emit_inner(cfg4), "White Male Incarceration: Texas vs Synthetic Texas", sub4),
wrap_block(emit_inner(cfg5), "Placebo Inference: Texas Against Every Donor State", sub5)
)
dir.create(dirname(path.expand(out_path)), recursive = TRUE, showWarnings = FALSE)
out_path <- path.expand(out_path)
writeLines(out, out_path)
cat("\nWrote", normalizePath(out_path), "\n")
cat(sprintf("Spec used: rung %d.\n", sel$rung))
cat("Blocks: proportional gap (lead), absolute gap, black fit, white fit, placebo.\n")
